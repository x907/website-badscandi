{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.badscandi.com" }],
      "destination": "https://badscandi.com/:path*",
      "permanent": true
    }
  ],
  "git": {
    "deploymentEnabled": {
      "dependabot/**": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/cart-abandonment",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/review-request",
      "schedule": "0 11 * * *"
    }
  ]
}
